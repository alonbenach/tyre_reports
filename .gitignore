# Environment / editor
.venv/
venv/
__pycache__/
.pytest_cache/
.mypy_cache/
.ruff_cache/
pytest-cache-files-*/
.vscode/

# Data and private business artifacts
data/
instructions/
reports/
logs/

# Database runtime artifacts
database/*.db
database/*.db-*
database/_test_work/
database/_export_work/
database/__pycache__/
tests/.pytest_cache/
tests/.tmp/
tests/pytest-cache-files-*/

# Keep only logo usage instructions; ignore logo assets
assets/logos/*
!assets/logos/README.md

# Prevent accidental commits of generated or source data files anywhere
*.csv
*.xlsx
*.xls
*.parquet
*.pdf
*.tsv
!tests/fixtures/**/*.csv
!tests/snapshots/**/*.csv
